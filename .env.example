NODE_ENV=development

BACKEND_HOST=0.0.0.0
BACKEND_PORT=3000
BACKEND_CORS_ORIGIN=http://localhost:5173

FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:3000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=inkflow
POSTGRES_USER=inkflow
POSTGRES_PASSWORD=inkflow_password
DATABASE_URL=postgresql://inkflow:inkflow_password@postgres:5432/inkflow?schema=public

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

LOG_LEVEL=info
SERVICE_NAME=inkflow-backend
GRACEFUL_SHUTDOWN_TIMEOUT_MS=10000
SWAGGER_TITLE=InkFlow API
SWAGGER_VERSION=0.1.0
BCRYPT_COST=10


NODE_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=3000
BACKEND_CORS_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://inkflow:inkflow_password@localhost:5432/inkflow?schema=public
REDIS_URL=redis://localhost:6379
LOG_LEVEL=info
SERVICE_NAME=inkflow-backend
GRACEFUL_SHUTDOWN_TIMEOUT_MS=10000
SWAGGER_TITLE=InkFlow API
SWAGGER_VERSION=0.1.0
BCRYPT_COST=10
REFRESH_TOKEN_TTL_DAYS=30
JWT_ACCESS_SECRET=supersecretjwtkeythatisextremelylongandsecuretoavoidattacks
JWT_ACCESS_TOKEN_TTL_MINUTES=15



